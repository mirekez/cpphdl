+//===- ExportCppHDL.h - C++HDL exporter -------------------------*- C++ -*-===//
+
+#ifndef CIRCT_CONVERSION_EXPORTCPPHDL_H
+#define CIRCT_CONVERSION_EXPORTCPPHDL_H
+
+#include "mlir/Support/LogicalResult.h"
+
+namespace llvm {
+class raw_ostream;
+class StringRef;
+}
+
+namespace mlir {
+class ModuleOp;
+}
+
+namespace circt {
+
+/// Emit a C++HDL representation of the lowered HW/Comb/Seq circuit.
+mlir::LogicalResult exportCppHDL(mlir::ModuleOp module,
+                                llvm::raw_ostream &os);
+
+/// Emit one header and implementation file per module into `directory`.
+mlir::LogicalResult exportSplitCppHDL(mlir::ModuleOp module,
+                                     llvm::StringRef directory);
+
+} // namespace circt
+
+#endif // CIRCT_CONVERSION_EXPORTCPPHDL_H
