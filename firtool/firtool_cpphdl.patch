diff --git a/lib/Conversion/ExportCppHDL/ExportCppHDL.cpp b/lib/Conversion/ExportCppHDL/ExportCppHDL.cpp
new file mode 100644
index 0000000..5a24381
--- /dev/null
+++ b/lib/Conversion/ExportCppHDL/ExportCppHDL.cpp
@@ -0,0 +1,850 @@
+//===- ExportCppHDL.cpp - C++HDL emitter --------------------------------===//
+
+#include "circt/Conversion/ExportCppHDL.h"
+
+#include "circt/Dialect/HW/HWOps.h"
+#include "circt/Dialect/HW/HWTypes.h"
+#include "circt/Dialect/Seq/SeqTypes.h"
+#include "circt/Dialect/Seq/SeqOps.h"
+#include "llvm/ADT/DenseMap.h"
+#include "llvm/ADT/SmallString.h"
+#include "llvm/ADT/StringExtras.h"
+#include "llvm/ADT/StringSet.h"
+#include "llvm/Support/FormatVariadic.h"
+#include "llvm/Support/FileSystem.h"
+#include "llvm/Support/Path.h"
+#include "llvm/Support/raw_ostream.h"
+#include "mlir/IR/BuiltinOps.h"
+#include "mlir/IR/Operation.h"
+
+using namespace mlir;
+using namespace circt;
+
+namespace {
+
+static void emitCppHDLSupport(raw_ostream &os) {
+  os << "// Generated directly from FIRRTL by firtool.\n"
+        "#pragma once\n#include <cpphdl.h>\n#include <type_traits>\n\n"
+        "namespace firtool_cpphdl {\n"
+        "template <size_t Width> cpphdl::logic<Width> constant(std::initializer_list<uint64_t> words) {\n"
+        "  cpphdl::logic<Width> result = 0; size_t word = 0;\n"
+        "  for (uint64_t value : words) { for (size_t bit = 0; bit < 64 && word * 64 + bit < Width; ++bit)\n"
+        "    result.set(word * 64 + bit, (value >> bit) & 1); ++word; } return result;\n"
+        "}\n"
+        "template <size_t ElementWidth, size_t Count, typename Index>\n"
+        "cpphdl::logic<ElementWidth> array_get(const cpphdl::logic<ElementWidth * Count>& value, const Index& index) {\n"
+        "  cpphdl::logic<ElementWidth> result = 0; size_t first = static_cast<uint64_t>(index) * ElementWidth;\n"
+        "  for (size_t bit = 0; bit < ElementWidth; ++bit) if (first + bit < ElementWidth * Count) result.set(bit, value.get(first + bit));\n"
+        "  return result;\n"
+        "}\n"
+        "template <size_t Width, typename Value> cpphdl::logic<Width> truncate(const Value& value) {\n"
+        "  cpphdl::logic<Width> result(value);\n"
+        "  for (size_t bit = Width; bit < cpphdl::logic<Width>::SIZE * 8; ++bit) result.set(bit, 0);\n"
+        "  return result;\n"
+        "}\n"
+        "template <size_t Width, typename Shift> cpphdl::logic<Width> ashr(const cpphdl::logic<Width>& value, const Shift& amount) {\n"
+        "  cpphdl::logic<Width> result = 0; size_t shift = static_cast<uint64_t>(amount); bool sign = value.get(Width - 1);\n"
+        "  for (size_t bit = 0; bit < Width; ++bit) result.set(bit, bit + shift < Width ? value.get(bit + shift) : sign);\n"
+        "  return result;\n"
+        "}\n} // namespace firtool_cpphdl\n";
+}
+
+static FailureOr<std::unique_ptr<llvm::raw_fd_ostream>>
+openGeneratedFile(StringRef directory, const Twine &filename) {
+  SmallString<256> path(directory);
+  llvm::sys::path::append(path, filename.str());
+  std::error_code error;
+  auto stream = std::make_unique<llvm::raw_fd_ostream>(path, error);
+  if (error) {
+    llvm::errs() << "cannot create C++HDL file '" << path
+                 << "': " << error.message() << "\n";
+    return failure();
+  }
+  return std::move(stream);
+}
+
+static std::string cppIdentifier(StringRef value) {
+  std::string result;
+  result.reserve(value.size() + 1);
+  if (value.empty() || llvm::isDigit(value.front()))
+    result.push_back('_');
+  for (char ch : value)
+    result.push_back(llvm::isAlnum(ch) || ch == '_' ? ch : '_');
+  return result;
+}
+
+static std::string cppInstanceName(StringRef value) {
+  return "inst_" + cppIdentifier(value);
+}
+
+static FailureOr<unsigned> bitWidth(Type type) {
+  if (isa<seq::ClockType>(type))
+    return 1;
+  auto width = hw::getBitWidth(type);
+  if (width <= 0)
+    return failure();
+  return static_cast<unsigned>(width);
+}
+
+static FailureOr<std::string> cppType(Type type) {
+  auto width = bitWidth(type);
+  if (failed(width))
+    return failure();
+  return (llvm::Twine("cpphdl::logic<") + llvm::Twine(*width) + ">").str();
+}
+
+class ModuleEmitter {
+public:
+  ModuleEmitter(ModuleOp circuit, hw::HWModuleOp module, raw_ostream &os,
+                raw_ostream *implementation = nullptr)
+      : circuit(circuit), module(module), os(os), implementation(implementation),
+        split(implementation != nullptr),
+        moduleName(cppIdentifier(module.getModuleName())) {}
+
+  LogicalResult emit() {
+    os << "class " << moduleName << " : public cpphdl::Module {\npublic:\n";
+
+    auto ports = module.getPortList();
+    for (auto port : ports) {
+      auto type = cppType(port.type);
+      if (failed(type))
+        return module.emitError("C++HDL cannot emit port '")
+               << port.getName() << "' with type " << port.type;
+      auto name = cppIdentifier(port.getName());
+      os << "  _PORT(" << *type << ") " << name << ";";
+      os << " // " << (port.isOutput() ? "output" : port.isInOut() ? "inout" : "input")
+         << "\n";
+      if (!port.isOutput())
+        names[module.getBodyBlock()->getArgument(port.argNum)] = name + "()";
+    }
+
+    unsigned nextValue = 0;
+    for (Operation &op : module.getBodyBlock()->getOperations()) {
+      if (op.getName().getStringRef() == "hw.output")
+        continue;
+      for (Value result : op.getResults()) {
+        if (op.getName().getStringRef() == "seq.firmem") {
+          auto requested = op.getAttrOfType<StringAttr>("name");
+          auto base = requested && !requested.getValue().empty()
+                          ? cppIdentifier(requested.getValue())
+                          : "memory";
+          names[result] = base + "_" + std::to_string(nextValue++);
+        } else if (op.getName().getStringRef() == "hw.instance") {
+          auto instance = cppInstanceName(
+              op.getAttrOfType<StringAttr>("instanceName").getValue());
+          auto resultNames = op.getAttrOfType<ArrayAttr>("resultNames");
+          auto resultIndex = mlir::cast<OpResult>(result).getResultNumber();
+          auto port = resultNames && resultIndex < resultNames.size()
+                          ? cppIdentifier(cast<StringAttr>(resultNames[resultIndex])
+                                              .getValue())
+                          : "result_" + std::to_string(resultIndex);
+          names[result] = instance + (split ? "->" : ".") + port + "()";
+        } else if (isSynchronousMemoryRead(op)) {
+          names[result] = "memory_read_" + std::to_string(nextValue++);
+        } else if (op.getName().getStringRef() == "seq.firreg") {
+          auto requested = op.getAttrOfType<StringAttr>("name");
+          auto base = requested && !requested.getValue().empty()
+                          ? cppIdentifier(requested.getValue())
+                          : "reg";
+          names[result] = base + "_" + std::to_string(nextValue++);
+        } else {
+          names[result] = "v" + std::to_string(nextValue++) + "()";
+        }
+      }
+    }
+
+    os << "\nprivate:\n";
+    for (Operation &op : module.getBodyBlock()->getOperations()) {
+      if (op.getName().getStringRef() != "seq.firmem")
+        continue;
+      auto memoryType = dyn_cast<seq::FirMemType>(op.getResult(0).getType());
+      if (!memoryType)
+        return op.emitError("malformed C++HDL FIRRTL memory type");
+      os << "  cpphdl::memory<cpphdl::u8, "
+         << (memoryType.getWidth() + 7) / 8 << ", " << memoryType.getDepth()
+         << "> " << names.lookup(op.getResult(0)) << ";\n";
+    }
+    for (Operation &op : module.getBodyBlock()->getOperations()) {
+      if (op.getName().getStringRef() != "hw.instance")
+        continue;
+      auto target = op.getAttrOfType<FlatSymbolRefAttr>("moduleName");
+      auto instanceName = op.getAttrOfType<StringAttr>("instanceName");
+      if (!target || !instanceName)
+        return op.emitError("malformed hw.instance for C++HDL");
+      os << "  " << cppIdentifier(target.getValue())
+         << (split ? "* " : " ") << cppInstanceName(instanceName.getValue())
+         << ";\n";
+    }
+    for (Operation &op : module.getBodyBlock()->getOperations()) {
+      if (op.getName().getStringRef() != "seq.firreg")
+        continue;
+      auto type = cppType(op.getResult(0).getType());
+      if (failed(type))
+        return op.emitError("C++HDL cannot emit register type ")
+               << op.getResult(0).getType();
+      os << "  cpphdl::reg<" << *type << "> " << names.lookup(op.getResult(0))
+         << "{};\n";
+    }
+    for (Operation &op : module.getBodyBlock()->getOperations()) {
+      if (!isSynchronousMemoryRead(op))
+        continue;
+      auto type = cppType(op.getResult(0).getType());
+      if (failed(type))
+        return op.emitError("C++HDL cannot emit synchronous memory read type ")
+               << op.getResult(0).getType();
+      os << "  cpphdl::reg<" << *type << "> " << names.lookup(op.getResult(0))
+         << "{};\n";
+    }
+    for (Operation &op : module.getBodyBlock()->getOperations()) {
+      if (op.getNumResults() == 0 || op.getNumRegions() != 0)
+        continue;
+      if (op.getName().getStringRef() == "seq.firreg" ||
+          op.getName().getStringRef() == "seq.firmem" ||
+          op.getName().getStringRef() == "hw.instance" ||
+          isSynchronousMemoryRead(op))
+        continue;
+      if (failed(emitValueOperation(op)))
+        return failure();
+    }
+
+    auto *terminator = module.getBodyBlock()->getTerminator();
+    if (!terminator || terminator->getName().getStringRef() != "hw.output")
+      return module.emitError("C++HDL expected an hw.output terminator");
+
+    raw_ostream &body = split ? *implementation : os;
+    if (split) {
+      os << "\npublic:\n  " << moduleName << "();\n  ~" << moduleName
+         << "();\n  void _assign();\n  void _work(bool);\n  void _strobe();\n};\n";
+      body << moduleName << "::" << moduleName << "() {\n";
+      for (Operation &op : module.getBodyBlock()->getOperations()) {
+        if (op.getName().getStringRef() != "hw.instance")
+          continue;
+        auto target = op.getAttrOfType<FlatSymbolRefAttr>("moduleName");
+        auto instanceName = op.getAttrOfType<StringAttr>("instanceName");
+        body << "  " << cppInstanceName(instanceName.getValue()) << " = new "
+             << cppIdentifier(target.getValue()) << "();\n";
+      }
+      body << "}\n\n" << moduleName << "::~" << moduleName << "() {\n";
+      for (Operation &op : module.getBodyBlock()->getOperations())
+        if (op.getName().getStringRef() == "hw.instance")
+          body << "  delete "
+               << cppInstanceName(
+                      op.getAttrOfType<StringAttr>("instanceName").getValue())
+               << ";\n";
+      body << "}\n\nvoid " << moduleName << "::_assign() {\n";
+    } else {
+      os << "\npublic:\n  void _assign() {\n";
+    }
+    for (Operation &op : module.getBodyBlock()->getOperations()) {
+      if (op.getName().getStringRef() != "hw.instance")
+        continue;
+      auto instanceName = cppInstanceName(
+          op.getAttrOfType<StringAttr>("instanceName").getValue());
+      auto argumentNames = op.getAttrOfType<ArrayAttr>("argNames");
+      for (auto [index, operand] : llvm::enumerate(op.getOperands())) {
+        auto value = valueExpr(operand);
+        if (failed(value))
+          return failure();
+        auto port = argumentNames && index < argumentNames.size()
+                        ? cppIdentifier(cast<StringAttr>(argumentNames[index])
+                                            .getValue())
+                        : "argument_" + std::to_string(index);
+        body << "    " << instanceName << (split ? "->" : ".") << port
+             << " = _ASSIGN(" << *value << ");\n";
+      }
+      body << "    " << instanceName << (split ? "->" : ".")
+           << "_assign();\n";
+    }
+    unsigned outputIndex = 0;
+    for (auto port : ports) {
+      if (!port.isOutput())
+        continue;
+      auto value = valueExpr(terminator->getOperand(outputIndex++));
+      if (failed(value))
+        return failure();
+      body << "    " << cppIdentifier(port.getName()) << " = _ASSIGN(" << *value
+           << ");\n";
+    }
+    if (split)
+      body << "}\n\nvoid " << moduleName << "::_work(bool) {\n";
+    else
+      body << "  }\n\n  void _work(bool) {\n";
+    for (Operation &op : module.getBodyBlock()->getOperations()) {
+      if (op.getName().getStringRef() != "seq.firreg")
+        continue;
+      if (op.getNumOperands() < 2)
+        return op.emitError("malformed seq.firreg for C++HDL");
+      auto input = valueExpr(op.getOperand(0));
+      auto clock = valueExpr(op.getOperand(1));
+      if (failed(input) || failed(clock))
+        return failure();
+      auto regName = names.lookup(op.getResult(0));
+      body << "    if (" << *clock << ") {\n";
+      if (op.getNumOperands() >= 4) {
+        auto reset = valueExpr(op.getOperand(2));
+        auto resetValue = valueExpr(op.getOperand(3));
+        if (failed(reset) || failed(resetValue))
+          return failure();
+        body << "      if (" << *reset << ") " << regName << "._next = "
+             << *resetValue << "; else " << regName << "._next = " << *input
+             << ";\n";
+      } else {
+        body << "      " << regName << "._next = " << *input << ";\n";
+      }
+      body << "    } else " << regName << "._next = " << regName << ";\n";
+    }
+    for (Operation &operation : module.getBodyBlock()->getOperations()) {
+      Value memory, address, clock, enable, mode;
+      if (auto read = dyn_cast<seq::FirMemReadOp>(operation)) {
+        memory = read.getMemory();
+        address = read.getAddress();
+        clock = read.getClk();
+        enable = read.getEnable();
+      } else if (auto readWrite = dyn_cast<seq::FirMemReadWriteOp>(operation)) {
+        memory = readWrite.getMemory();
+        address = readWrite.getAddress();
+        clock = readWrite.getClk();
+        enable = readWrite.getEnable();
+        mode = readWrite.getMode();
+      } else {
+        continue;
+      }
+      if (!isSynchronousMemoryRead(operation))
+        continue;
+      auto memoryExpr = valueExpr(memory);
+      auto addressExpr = valueExpr(address);
+      auto clockExpr = valueExpr(clock);
+      if (failed(memoryExpr) || failed(addressExpr) || failed(clockExpr))
+        return failure();
+      std::string condition = *clockExpr;
+      if (enable) {
+        auto enableExpr = valueExpr(enable);
+        if (failed(enableExpr))
+          return failure();
+        condition += " && " + *enableExpr;
+      }
+      if (mode) {
+        auto modeExpr = valueExpr(mode);
+        if (failed(modeExpr))
+          return failure();
+        condition += " && !(" + *modeExpr + ")";
+      }
+      auto memoryType = cast<seq::FirMemType>(memory.getType());
+      auto readName = names.lookup(operation.getResult(0));
+      body << "    if (" << condition << ") " << readName << "._next = "
+           << *memoryExpr << "[static_cast<uint64_t>(" << *addressExpr << ") % "
+           << memoryType.getDepth() << "]; else " << readName << "._next = "
+           << readName << ";\n";
+    }
+    for (Operation &operation : module.getBodyBlock()->getOperations()) {
+      auto write = dyn_cast<seq::FirMemWriteOp>(operation);
+      if (!write)
+        continue;
+      auto memory = valueExpr(write.getMemory());
+      auto address = valueExpr(write.getAddress());
+      auto data = valueExpr(write.getData());
+      auto clock = valueExpr(write.getClk());
+      if (failed(memory) || failed(address) || failed(data) || failed(clock))
+        return failure();
+      std::string enable = "true";
+      if (write.getEnable()) {
+        auto value = valueExpr(write.getEnable());
+        if (failed(value))
+          return failure();
+        enable = *value;
+      }
+      body << "    if (" << *clock << " && " << enable << ") {\n";
+      if (!write.getMask()) {
+        auto depth = cast<seq::FirMemType>(write.getMemory().getType()).getDepth();
+        body << "      " << *memory << "[static_cast<uint64_t>(" << *address
+             << ") % " << depth << "] = " << *data << ";\n";
+      } else {
+        auto mask = valueExpr(write.getMask());
+        auto memoryType = cast<seq::FirMemType>(write.getMemory().getType());
+        auto maskWidth = memoryType.getMaskWidth().value_or(1);
+        auto chunkWidth = memoryType.getWidth() / maskWidth;
+        if (failed(mask))
+          return failure();
+        body << "      auto row = " << *memory << "[static_cast<uint64_t>("
+           << *address << ") % " << memoryType.getDepth() << "];\n"
+           << "      cpphdl::logic<" << memoryType.getWidth()
+           << "> merged = row;\n"
+           << "      for (size_t chunk = 0; chunk < " << maskWidth
+           << "; ++chunk) if (" << *mask << ".get(chunk))\n"
+           << "        merged.bits((chunk + 1) * " << chunkWidth
+           << " - 1, chunk * " << chunkWidth << ") = " << *data
+           << ".bits((chunk + 1) * " << chunkWidth << " - 1, chunk * "
+           << chunkWidth << ");\n"
+           << "      row = merged;\n";
+      }
+      body << "    }\n";
+    }
+    for (Operation &operation : module.getBodyBlock()->getOperations()) {
+      auto write = dyn_cast<seq::FirMemReadWriteOp>(operation);
+      if (!write)
+        continue;
+      auto memory = valueExpr(write.getMemory());
+      auto address = valueExpr(write.getAddress());
+      auto data = valueExpr(write.getWriteData());
+      auto clock = valueExpr(write.getClk());
+      auto mode = valueExpr(write.getMode());
+      if (failed(memory) || failed(address) || failed(data) || failed(clock) ||
+          failed(mode))
+        return failure();
+      std::string enable = "true";
+      if (write.getEnable()) {
+        auto value = valueExpr(write.getEnable());
+        if (failed(value))
+          return failure();
+        enable = *value;
+      }
+      body << "    if (" << *clock << " && " << enable << " && " << *mode
+           << ") {\n";
+      auto memoryType = cast<seq::FirMemType>(write.getMemory().getType());
+      if (!write.getMask()) {
+        body << "      " << *memory << "[static_cast<uint64_t>(" << *address
+             << ") % " << memoryType.getDepth() << "] = " << *data << ";\n";
+      } else {
+        auto mask = valueExpr(write.getMask());
+        auto maskWidth = memoryType.getMaskWidth().value_or(1);
+        auto chunkWidth = memoryType.getWidth() / maskWidth;
+        if (failed(mask))
+          return failure();
+        body << "      auto row = " << *memory << "[static_cast<uint64_t>("
+             << *address << ") % " << memoryType.getDepth() << "];\n"
+             << "      cpphdl::logic<" << memoryType.getWidth()
+             << "> merged = row;\n"
+             << "      for (size_t chunk = 0; chunk < " << maskWidth
+             << "; ++chunk) if (" << *mask << ".get(chunk))\n"
+             << "        merged.bits((chunk + 1) * " << chunkWidth
+             << " - 1, chunk * " << chunkWidth << ") = " << *data
+             << ".bits((chunk + 1) * " << chunkWidth << " - 1, chunk * "
+             << chunkWidth << ");\n"
+             << "      row = merged;\n";
+      }
+      body << "    }\n";
+    }
+    for (Operation &op : module.getBodyBlock()->getOperations())
+      if (op.getName().getStringRef() == "hw.instance")
+        body << "    "
+           << cppInstanceName(op.getAttrOfType<StringAttr>("instanceName").getValue())
+           << (split ? "->_work(false);\n" : "._work(false);\n");
+    if (split)
+      body << "}\n\nvoid " << moduleName << "::_strobe() {\n";
+    else
+      body << "  }\n\n  void _strobe() {\n";
+    for (Operation &op : module.getBodyBlock()->getOperations())
+      if (op.getName().getStringRef() == "seq.firreg")
+        body << "    " << names.lookup(op.getResult(0)) << ".strobe();\n";
+    for (Operation &op : module.getBodyBlock()->getOperations())
+      if (isSynchronousMemoryRead(op))
+        body << "    " << names.lookup(op.getResult(0)) << ".strobe();\n";
+    for (Operation &op : module.getBodyBlock()->getOperations())
+      if (op.getName().getStringRef() == "seq.firmem")
+        body << "    " << names.lookup(op.getResult(0)) << ".apply();\n";
+    for (Operation &op : module.getBodyBlock()->getOperations())
+      if (op.getName().getStringRef() == "hw.instance")
+        body << "    "
+           << cppInstanceName(op.getAttrOfType<StringAttr>("instanceName").getValue())
+           << (split ? "->_strobe();\n" : "._strobe();\n");
+    body << (split ? "}\n\n" : "  }\n};\n\n");
+    return success();
+  }
+
+private:
+  FailureOr<std::string> valueExpr(Value value) {
+    auto it = names.find(value);
+    if (it == names.end()) {
+      mlir::emitError(value.getLoc(), "C++HDL has no expression for value");
+      return failure();
+    }
+    return it->second;
+  }
+
+  LogicalResult emitValueOperation(Operation &op) {
+    if (op.getNumResults() != 1)
+      return op.emitError("C++HDL currently requires one result per operation");
+    auto type = cppType(op.getResult(0).getType());
+    if (failed(type))
+      return op.emitError("C++HDL cannot emit result type ")
+             << op.getResult(0).getType();
+    auto expr = operationExpr(op);
+    if (failed(expr))
+      return failure();
+    auto functionCall = names.lookup(op.getResult(0));
+    auto functionName = StringRef(functionCall).drop_back(2);
+    if (split) {
+      os << "  " << *type << " " << functionName << "_cache{};\n"
+         << "  long " << functionName << "_clock = -1;\n"
+         << "  " << *type << "& " << functionName << "();\n";
+      *implementation << *type << "& " << moduleName << "::" << functionName
+                      << "() {\n  if (" << functionName
+                      << "_clock == _system_clock) return " << functionName
+                      << "_cache;\n  " << functionName
+                      << "_clock = _system_clock;\n  return " << functionName
+                      << "_cache = " << *expr << ";\n}\n";
+    } else {
+      os << "  " << *type << " " << functionName << "() { return " << *expr
+         << "; }\n";
+    }
+    return success();
+  }
+
+  FailureOr<std::string> operationExpr(Operation &op) {
+    auto name = op.getName().getStringRef();
+    SmallVector<std::string> operands;
+    for (Value operand : op.getOperands()) {
+      auto value = valueExpr(operand);
+      if (failed(value))
+        return failure();
+      operands.push_back(*value);
+    }
+    auto resultWidth = bitWidth(op.getResult(0).getType());
+    if (failed(resultWidth))
+      return failure();
+    auto castResult = [&](const Twine &expr) {
+      return (Twine("firtool_cpphdl::truncate<") + Twine(*resultWidth) + ">(" +
+              expr + ")")
+          .str();
+    };
+
+    if (name == "hw.constant") {
+      auto value = op.getAttrOfType<IntegerAttr>("value");
+      if (!value)
+        return op.emitError("C++HDL hw.constant has no value");
+      SmallVector<std::string> words;
+      const auto &integer = value.getValue();
+      for (unsigned bit = 0; bit < integer.getBitWidth(); bit += 64)
+        words.push_back((Twine("0x") +
+                         llvm::utohexstr(integer.extractBitsAsZExtValue(
+                             std::min(64U, integer.getBitWidth() - bit), bit)) +
+                         "ULL")
+                            .str());
+      return (Twine("firtool_cpphdl::constant<") + Twine(*resultWidth) +
+              ">({" + llvm::join(words, ", ") + "})")
+          .str();
+    }
+    if (name == "hw.aggregate_constant") {
+      auto fields = op.getAttrOfType<ArrayAttr>("fields");
+      if (!fields)
+        return op.emitError("C++HDL aggregate constant has no fields");
+      if (fields.empty())
+        return castResult("0");
+      unsigned fieldWidth = *resultWidth / fields.size();
+      SmallVector<std::string> widths, values;
+      for (Attribute field : fields) {
+        auto integer = dyn_cast<IntegerAttr>(field);
+        if (!integer || integer.getValue().getActiveBits() > 64)
+          return op.emitError("unsupported C++HDL aggregate constant field");
+        widths.push_back(std::to_string(fieldWidth));
+        values.push_back((Twine("cpphdl::logic<") + Twine(fieldWidth) + ">(" +
+                          Twine(integer.getValue().getZExtValue()) + "ULL)")
+                             .str());
+      }
+      return (Twine("cpphdl::cat<") + llvm::join(widths, ", ") + ">(" +
+              llvm::join(values, ", ") + ")")
+          .str();
+    }
+    if (name == "comb.mux" && operands.size() == 3)
+      return castResult(Twine("(") + operands[0] + " ? " + operands[1] + " : " + operands[2] + ")");
+
+    if ((name == "comb.shl" || name == "comb.shru") && operands.size() == 2) {
+      StringRef shiftToken = name == "comb.shl" ? " << " : " >> ";
+      return castResult(Twine("(firtool_cpphdl::truncate<") +
+                        Twine(*resultWidth) + ">(" + operands[0] + ")" +
+                        shiftToken + "static_cast<size_t>(" + operands[1] +
+                        "))");
+    }
+
+    StringRef token;
+    if (name == "comb.and") token = " & ";
+    else if (name == "comb.or") token = " | ";
+    else if (name == "comb.xor") token = " ^ ";
+    else if (name == "comb.add") token = " + ";
+    else if (name == "comb.sub") token = " - ";
+    else if (name == "comb.mul") token = " * ";
+    if (!token.empty() && !operands.empty())
+      return castResult(Twine("(") + llvm::join(operands, token) + ")");
+
+    if (name == "comb.extract" && operands.size() == 1) {
+      auto low = op.getAttrOfType<IntegerAttr>("lowBit");
+      if (!low)
+        low = op.getAttrOfType<IntegerAttr>("low_bit");
+      if (!low)
+        return op.emitError("C++HDL comb.extract is missing low-bit attribute");
+      auto first = low.getInt();
+      auto last = first + *resultWidth - 1;
+      return castResult(Twine(operands[0]) + ".bits(" + Twine(last) + ", " + Twine(first) + ")");
+    }
+
+    if (name == "comb.concat" && !operands.empty()) {
+      SmallVector<std::string> widths;
+      for (Value operand : op.getOperands()) {
+        auto width = bitWidth(operand.getType());
+        if (failed(width))
+          return failure();
+        widths.push_back(std::to_string(*width));
+      }
+      return (Twine("cpphdl::cat<") + llvm::join(widths, ", ") + ">(" +
+              llvm::join(operands, ", ") + ")").str();
+    }
+
+    if ((name == "hw.array_create" || name == "hw.array_concat") &&
+        !operands.empty()) {
+      SmallVector<std::string> widths;
+      for (Value operand : op.getOperands()) {
+        auto width = bitWidth(operand.getType());
+        if (failed(width))
+          return failure();
+        widths.push_back(std::to_string(*width));
+      }
+      return (Twine("cpphdl::cat<") + llvm::join(widths, ", ") + ">(" +
+              llvm::join(operands, ", ") + ")")
+          .str();
+    }
+
+    if (name == "hw.array_get" && operands.size() == 2) {
+      auto inputWidth = bitWidth(op.getOperand(0).getType());
+      if (failed(inputWidth) || *inputWidth % *resultWidth)
+        return op.emitError("invalid C++HDL array_get widths");
+      return (Twine("firtool_cpphdl::array_get<") + Twine(*resultWidth) +
+              ", " + Twine(*inputWidth / *resultWidth) + ">(" + operands[0] +
+              ", " + operands[1] + ")")
+          .str();
+    }
+
+    if (name == "comb.replicate" && operands.size() == 1) {
+      auto inputWidth = bitWidth(op.getOperand(0).getType());
+      if (failed(inputWidth) || *resultWidth % *inputWidth)
+        return op.emitError("invalid C++HDL replicate widths");
+      return (Twine("cpphdl::repeat<") + Twine(*resultWidth / *inputWidth) +
+              ">(" + operands[0] + ")")
+          .str();
+    }
+
+    if (name == "comb.icmp" && operands.size() == 2) {
+      auto predicateAttr = op.getAttrOfType<IntegerAttr>("predicate");
+      if (!predicateAttr)
+        return op.emitError("C++HDL comparison has no predicate");
+      StringRef compare;
+      auto predicate = predicateAttr.getInt();
+      switch (predicate) {
+      case 0: case 10: case 12: compare = " == "; break;
+      case 1: case 11: case 13: compare = " != "; break;
+      case 2: case 6: compare = " < "; break;
+      case 3: case 7: compare = " <= "; break;
+      case 4: case 8: compare = " > "; break;
+      case 5: case 9: compare = " >= "; break;
+      default:
+        return op.emitError("unsupported C++HDL comparison predicate ")
+               << predicate;
+      }
+      bool isSigned = predicate >= 2 && predicate <= 5;
+      if (isSigned) {
+        auto inputWidth = bitWidth(op.getOperand(0).getType());
+        if (failed(inputWidth))
+          return failure();
+        operands[0] = (Twine("cpphdl::sv_signed<") + Twine(*inputWidth) +
+                       ">(" + operands[0] + ")")
+                          .str();
+        operands[1] = (Twine("cpphdl::sv_signed<") + Twine(*inputWidth) +
+                       ">(" + operands[1] + ")")
+                          .str();
+      }
+      return castResult(Twine("(") + operands[0] + compare + operands[1] + ")");
+    }
+
+    if ((name == "seq.from_clock" || name == "seq.to_clock") &&
+        operands.size() == 1)
+      return castResult(operands[0]);
+
+    if (name == "hw.wire" && operands.size() == 1)
+      return castResult(operands[0]);
+
+    if (name == "comb.shrs" && operands.size() == 2)
+      return (Twine("firtool_cpphdl::ashr<") + Twine(*resultWidth) + ">(" +
+              operands[0] + ", " + operands[1] + ")")
+          .str();
+
+    if (name == "seq.firmem.read_port" && operands.size() >= 2) {
+      auto memoryType = cast<seq::FirMemType>(op.getOperand(0).getType());
+      return castResult(Twine(operands[0]) + "[static_cast<uint64_t>(" +
+                        operands[1] + ") % " + Twine(memoryType.getDepth()) + "]");
+    }
+
+    if (name == "seq.firmem.read_write_port" && operands.size() >= 2) {
+      auto memoryType = cast<seq::FirMemType>(op.getOperand(0).getType());
+      return castResult(Twine(operands[0]) + "[static_cast<uint64_t>(" +
+                        operands[1] + ") % " + Twine(memoryType.getDepth()) + "]");
+    }
+
+    return op.emitError("unsupported operation in direct C++HDL emission: ") << name;
+  }
+
+  bool isSynchronousMemoryRead(Operation &op) const {
+    Value memory;
+    if (auto read = dyn_cast<seq::FirMemReadOp>(op))
+      memory = read.getMemory();
+    else if (auto readWrite = dyn_cast<seq::FirMemReadWriteOp>(op))
+      memory = readWrite.getMemory();
+    else
+      return false;
+    auto declaration = memory.getDefiningOp<seq::FirMemOp>();
+    return declaration && declaration.getReadLatency() > 0;
+  }
+
+  ModuleOp circuit;
+  hw::HWModuleOp module;
+  raw_ostream &os;
+  raw_ostream *implementation;
+  bool split;
+  std::string moduleName;
+  llvm::DenseMap<Value, std::string> names;
+};
+
+static LogicalResult emitSplitExternal(hw::HWModuleExternOp external,
+                                       raw_ostream &header,
+                                       raw_ostream &implementation) {
+  auto name = cppIdentifier(external.getModuleName());
+  header << "#pragma once\n#include \"cpphdl_support.h\"\n"
+            "#include <memory>\n#include <utility>\n\nclass "
+         << name << " : public cpphdl::Module {\npublic:\n";
+  for (auto port : external.getPortList()) {
+    auto type = cppType(port.type);
+    if (failed(type))
+      return external.emitError("C++HDL cannot emit external port type ")
+             << port.type;
+    header << "  _PORT(" << *type << ") " << cppIdentifier(port.getName())
+           << "; // " << (port.isOutput() ? "output" : "input") << "\n";
+  }
+  header << "\nprivate:\n  std::shared_ptr<void> cpphdlExternalState;\n";
+  for (auto port : external.getPortList()) {
+    if (!port.isOutput())
+      continue;
+    auto type = cppType(port.type);
+    header << "  " << *type << " value_" << cppIdentifier(port.getName())
+           << " = 0;\n";
+  }
+  header << "\npublic:\n";
+  for (auto port : external.getPortList()) {
+    if (!port.isOutput())
+      continue;
+    auto type = cppType(port.type);
+    header << "  void cpphdl_drive_" << cppIdentifier(port.getName())
+           << "(const " << *type << " &value) { value_"
+           << cppIdentifier(port.getName()) << " = value; }\n";
+  }
+  header << "  template <typename State, typename... Args>\n"
+            "  State &cpphdl_external_state(Args &&...args) {\n"
+            "    if (!cpphdlExternalState)\n"
+            "      cpphdlExternalState = std::make_shared<State>(std::forward<Args>(args)...);\n"
+            "    return *static_cast<State *>(cpphdlExternalState.get());\n"
+            "  }\n\n  void _assign();\n  void _work(bool);\n"
+            "  void _strobe() {}\n};\n";
+
+  implementation << "#include \"" << name << ".h\"\n"
+                    "#if __has_include(\"cpphdl_external_models.h\")\n"
+                    "#include \"cpphdl_external_models.h\"\n"
+                    "#else\nnamespace firtool_cpphdl_external {\n"
+                    "template <typename Module> void work(Module &, bool) {}\n"
+                    "}\n#endif\n\n"
+                 << "void " << name << "::_assign() {\n";
+  for (auto port : external.getPortList())
+    if (port.isOutput())
+      implementation << "  " << cppIdentifier(port.getName())
+                     << " = _ASSIGN_REG(value_"
+                     << cppIdentifier(port.getName()) << ");\n";
+  implementation << "}\n\nvoid " << name << "::_work(bool edge) {\n"
+                 << "  firtool_cpphdl_external::work(*this, edge);\n}\n";
+  return success();
+}
+
+} // namespace
+
+LogicalResult circt::exportCppHDL(ModuleOp module, raw_ostream &os) {
+  emitCppHDLSupport(os);
+  os << "\n";
+  for (auto external : module.getOps<hw::HWModuleExternOp>()) {
+    os << "class " << cppIdentifier(external.getModuleName())
+       << " : public cpphdl::Module {\npublic:\n";
+    for (auto port : external.getPortList()) {
+      auto type = cppType(port.type);
+      if (failed(type))
+        return external.emitError("C++HDL cannot emit external port type ")
+               << port.type;
+      os << "  _PORT(" << *type << ") " << cppIdentifier(port.getName())
+         << "; // " << (port.isOutput() ? "output" : "input") << "\n";
+    }
+    os << "  void _assign() {}\n  void _work(bool) {}\n  void _strobe() {}\n};\n\n";
+  }
+  for (auto hwModule : module.getOps<hw::HWModuleOp>())
+    if (failed(ModuleEmitter(module, hwModule, os).emit()))
+      return failure();
+  return success();
+}
+
+LogicalResult circt::exportSplitCppHDL(ModuleOp module, StringRef directory) {
+  if (auto error = llvm::sys::fs::create_directories(directory)) {
+    llvm::errs() << "cannot create C++HDL directory '" << directory
+                 << "': " << error.message() << "\n";
+    return failure();
+  }
+
+  auto support = openGeneratedFile(directory, "cpphdl_support.h");
+  if (failed(support))
+    return failure();
+  emitCppHDLSupport(**support);
+
+  SmallVector<std::string> sources;
+  for (auto external : module.getOps<hw::HWModuleExternOp>()) {
+    auto name = cppIdentifier(external.getModuleName());
+    auto header = openGeneratedFile(directory, name + ".h");
+    auto implementation = openGeneratedFile(directory, name + ".cpp");
+    if (failed(header) || failed(implementation))
+      return failure();
+    if (failed(emitSplitExternal(external, **header, **implementation)))
+      return failure();
+    sources.push_back(name + ".cpp");
+  }
+
+  for (auto hwModule : module.getOps<hw::HWModuleOp>()) {
+    auto name = cppIdentifier(hwModule.getModuleName());
+    auto header = openGeneratedFile(directory, name + ".h");
+    auto implementation = openGeneratedFile(directory, name + ".cpp");
+    if (failed(header) || failed(implementation))
+      return failure();
+    **header << "#pragma once\n#include \"cpphdl_support.h\"\n\n";
+    llvm::StringSet<> targets;
+    for (Operation &op : hwModule.getBodyBlock()->getOperations()) {
+      if (op.getName().getStringRef() != "hw.instance")
+        continue;
+      auto target = cppIdentifier(
+          op.getAttrOfType<FlatSymbolRefAttr>("moduleName").getValue());
+      if (targets.insert(target).second)
+        **header << "class " << target << ";\n";
+    }
+    **header << "\n";
+    **implementation << "#include \"" << name << ".h\"\n";
+    for (auto &target : targets)
+      **implementation << "#include \"" << target.getKey() << ".h\"\n";
+    **implementation << "\n";
+    if (failed(ModuleEmitter(module, hwModule, **header, &**implementation).emit()))
+      return failure();
+    sources.push_back(name + ".cpp");
+  }
+
+  auto cmake = openGeneratedFile(directory, "CMakeLists.txt");
+  if (failed(cmake))
+    return failure();
+  **cmake << "cmake_minimum_required(VERSION 3.20)\n"
+             "project(firtool_generated_cpphdl LANGUAGES CXX)\n"
+             "set(CMAKE_CXX_STANDARD 17)\n"
+             "set(CPPHDL_INCLUDE_DIR \"$ENV{HOME}/cpphdl/include\" CACHE PATH \"CppHDL include directory\")\n"
+             "add_library(firtool_generated_cpphdl OBJECT\n";
+  for (auto &source : sources)
+    **cmake << "  " << source << "\n";
+  **cmake << ")\nset(CPPHDL_OPT_LEVEL \"-O2\" CACHE STRING \"C++HDL simulator optimization flag\")\n"
+             "target_compile_options(firtool_generated_cpphdl PRIVATE ${CPPHDL_OPT_LEVEL})\n"
+             "target_include_directories(firtool_generated_cpphdl PUBLIC ${CMAKE_CURRENT_SOURCE_DIR} ${CPPHDL_INCLUDE_DIR})\n";
+  return success();
+}
